<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
    <div>
      <h1 class="h4 fw-bold mb-1">Câu hỏi</h1>
      <p class="text-muted small mb-0">Danh sách ngân hàng câu hỏi.</p>
    </div>
    <a href="/questions/create" class="btn btn-primary btn-sm">Tạo</a>
  </div>

  <% if (questions && questions.length > 0) { %>
    <div class="list-group">
      <% questions.forEach((q, index) => { %>
        <div class="list-group-item p-3 mb-2 border rounded bg-white">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <span class="fw-bold">
                <%= index + 1 %>. <%= q.text %>
              </span>
              <div class="mt-1">
                <% q.keywords.forEach(kw => { %>
                  <span class="badge bg-light text-dark border" style="font-size: 0.75rem;"><%= kw %></span>
                <% }) %>
              </div>
            </div>
            <div class="d-flex gap-2">
              <a href="/questions/<%= q._id %>" class="btn btn-outline-primary btn-sm">Xem</a>
              <a href="/questions/<%= q._id %>/edit" class="btn btn-outline-warning btn-sm">Sửa</a>
              <form action="/questions/<%= q._id %>?_method=DELETE" method="POST" onsubmit="return confirm('Bạn có chắc chắn muốn xóa câu hỏi này?');" class="d-inline">
                <button type="submit" class="btn btn-outline-danger btn-sm">Xóa</button>
              </form>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <div class="p-4 text-center my-4 bg-white border rounded">
      <p class="text-muted mb-0">Chưa có câu hỏi nào.</p>
      <a href="/questions/create" class="btn btn-primary btn-sm mt-2">Tạo</a>
    </div>
  <% } %>
</div>
