<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb small">
          <li class="breadcrumb-item"><a href="/questions">Câu hỏi</a></li>
          <li class="breadcrumb-item active" aria-current="page">Chi tiết</li>
        </ol>
      </nav>

      <div class="bg-white border rounded p-4">
        <div class="d-flex justify-content-between align-items-start pb-3 mb-4 border-bottom">
          <div>
            <h1 class="h4 fw-bold mb-1">Chi tiết</h1>
            <span class="text-muted small">ID: <%= question._id %></span>
          </div>
          <div class="d-flex gap-2">
            <a href="/questions/<%= question._id %>/edit" class="btn btn-warning btn-sm">Sửa</a>
            <form action="/questions/<%= question._id %>?_method=DELETE" method="POST" onsubmit="return confirm('Bạn có chắc chắn muốn xóa câu hỏi này không?');" class="d-inline">
              <button type="submit" class="btn btn-danger btn-sm">Xóa</button>
            </form>
          </div>
        </div>

        <div class="mb-4">
          <p class="fs-5 fw-bold"><%= question.text %></p>
        </div>

        <div class="mb-4">
          <p class="text-muted small fw-bold mb-2">Đáp án:</p>
          <div class="row g-2">
            <% question.options.forEach((opt, idx) => { %>
              <div class="col-md-6">
                <div class="p-2 border rounded small <%= idx === question.correctAnswerIndex ? 'bg-light border-dark' : 'bg-light' %>">
                  <div class="d-flex justify-content-between align-items-center">
                    <span>
                      <strong><%= String.fromCharCode(65 + idx) %>.</strong> <%= opt %>
                    </span>
                    <% if (idx === question.correctAnswerIndex) { %>
                      <span class="text-success small fw-bold">✓</span>
                    <% } %>
                  </div>
                </div>
              </div>
            <% }) %>
          </div>
        </div>

        <div class="mb-4">
          <p class="text-muted small fw-bold mb-2">Từ khóa:</p>
          <div>
            <% if (question.keywords && question.keywords.length > 0) { %>
              <% question.keywords.forEach(kw => { %>
                <span class="badge bg-light text-dark border"><%= kw %></span>
              <% }) %>
            <% } else { %>
              <span class="text-muted small">Không có.</span>
            <% } %>
          </div>
        </div>

        <div class="d-flex justify-content-between text-muted small pt-3 border-top mt-5">
          <span>Tạo: <%= new Date(question.createdAt).toLocaleDateString('vi-VN') %></span>
          <span>Cập nhật: <%= new Date(question.updatedAt).toLocaleDateString('vi-VN') %></span>
        </div>
      </div>
    </div>
  </div>
</div>
