<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb small">
          <li class="breadcrumb-item"><a href="/quizzes">Quiz</a></li>
          <li class="breadcrumb-item"><a href="/quizzes/<%= quiz._id %>">Chi tiết</a></li>
          <li class="breadcrumb-item active" aria-current="page">Sửa</li>
        </ol>
      </nav>

      <div class="bg-white border rounded p-4">
        <div class="pb-2 mb-4 border-bottom">
          <h1 class="h4 fw-bold">Sửa Quiz</h1>
        </div>

        <form action="/quizzes/<%= quiz._id %>?_method=PUT" method="POST">
          <div class="mb-3">
            <label for="title" class="form-label small fw-bold">Tiêu đề Quiz</label>
            <input type="text" class="form-control form-control-sm" id="title" name="title" value="<%= quiz.title %>" required>
          </div>

          <div class="mb-3">
            <label for="description" class="form-label small fw-bold">Mô tả</label>
            <textarea class="form-control form-control-sm" id="description" name="description" rows="3" required><%= quiz.description %></textarea>
          </div>

          <div class="mb-4">
            <label class="form-label small fw-bold">Danh sách câu hỏi trong Quiz</label>
            
            <% if (questions && questions.length > 0) { %>
              <div class="border rounded p-3 bg-light overflow-y-auto" style="max-height: 250px;">
                <% questions.forEach(q => { %>
                  <div class="form-check mb-2">
                    <% const isChecked = currentQuestionIds.includes(q._id.toString()) %>
                    <input class="form-check-input" type="checkbox" name="questions" value="<%= q._id %>" id="q_<%= q._id %>" <%= isChecked ? 'checked' : '' %>>
                    <label class="form-check-label text-dark small" for="q_<%= q._id %>">
                      <strong><%= q.text %></strong> 
                      <span class="text-muted d-block small">
                        Từ khóa: <%= q.keywords.join(', ') %>
                      </span>
                    </label>
                  </div>
                <% }) %>
              </div>
            <% } else { %>
              <div class="p-3 text-center border rounded text-muted small">
                Không có câu hỏi nào trong hệ thống.
              </div>
            <% } %>
          </div>

          <div class="d-flex gap-2 justify-content-end">
            <a href="/quizzes/<%= quiz._id %>" class="btn btn-secondary btn-sm">Hủy</a>
            <button type="submit" class="btn btn-primary btn-sm">Lưu</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
