{
  "info": {
    "name": "SimpleQuiz API",
    "description": "REST API for Quiz & Questions — Express + MongoDB + Mongoose",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://localhost:3443"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "questionId",
      "value": ""
    },
    {
      "key": "quizId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "POST Register Ordinary User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"authoruser\",\n  \"password\": \"authorpass\",\n  \"admin\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/signup",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "signup"
              ]
            }
          }
        },
        {
          "name": "POST Register Admin User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"adminuser\",\n  \"password\": \"adminpass\",\n  \"admin\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/signup",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "signup"
              ]
            }
          }
        },
        {
          "name": "POST Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "var json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "  pm.test('Token saved', () => pm.expect(json.token).to.be.a('string'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"authoruser\",\n  \"password\": \"authorpass\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "login"
              ]
            }
          }
        },
        {
          "name": "GET all users",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Questions",
      "item": [
        {
          "name": "GET all questions",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/question",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "question"
              ]
            }
          }
        },
        {
          "name": "GET question by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/question/{{questionId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "question",
                "{{questionId}}"
              ]
            }
          }
        },
        {
          "name": "POST create question",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('questionId', json._id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"What is the capital of France?\",\n  \"options\": [\"Berlin\", \"Madrid\", \"Paris\", \"Rome\"],\n  \"keywords\": [\"capital\", \"geography\"],\n  \"correctAnswerIndex\": 2\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/question",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "question"
              ]
            }
          }
        },
        {
          "name": "PUT update question",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"What is the capital of France? (UPDATED)\",\n  \"options\": [\"Berlin\", \"Madrid\", \"Paris\", \"Rome\"],\n  \"keywords\": [\"capital\", \"geography\", \"updated\"],\n  \"correctAnswerIndex\": 2\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/question/{{questionId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "question",
                "{{questionId}}"
              ]
            }
          }
        },
        {
          "name": "DELETE question",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/question/{{questionId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "question",
                "{{questionId}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Quizzes",
      "item": [
        {
          "name": "GET all quizzes",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/quizzes",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "quizzes"
              ]
            }
          }
        },
        {
          "name": "GET quiz by ID (populated)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/quizzes/{{quizId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "quizzes",
                "{{quizId}}"
              ]
            }
          }
        },
        {
          "name": "POST create quiz",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('quizId', json._id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Capital Cities Quiz\",\n  \"description\": \"A quiz about world capitals\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/quizzes",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "quizzes"
              ]
            }
          }
        },
        {
          "name": "PUT update quiz",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"World Capitals Quiz (Updated)\",\n  \"description\": \"Updated description\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/quizzes/{{quizId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "quizzes",
                "{{quizId}}"
              ]
            }
          }
        },
        {
          "name": "DELETE quiz",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/quizzes/{{quizId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "quizzes",
                "{{quizId}}"
              ]
            }
          }
        },
        {
          "name": "Populate quiz with capital keyword",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/quizzes/{{quizId}}/populate",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "quizzes",
                "{{quizId}}",
                "populate"
              ]
            }
          }
        },
        {
          "name": "Add single question to quiz",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"What is the capital of Brazil?\",\n  \"options\": [\"Rio\", \"São Paulo\", \"Brasília\", \"Salvador\"],\n  \"keywords\": [\"capital\", \"south america\"],\n  \"correctAnswerIndex\": 2\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/quizzes/{{quizId}}/question",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "quizzes",
                "{{quizId}}",
                "question"
              ]
            }
          }
        },
        {
          "name": "Add multiple questions to quiz",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"questions\": [\n    {\n      \"text\": \"What is the capital of Australia?\",\n      \"options\": [\"Sydney\", \"Melbourne\", \"Canberra\", \"Perth\"],\n      \"keywords\": [\"capital\", \"oceania\"],\n      \"correctAnswerIndex\": 2\n    },\n    {\n      \"text\": \"What is the capital of Canada?\",\n      \"options\": [\"Toronto\", \"Vancouver\", \"Ottawa\", \"Montreal\"],\n      \"keywords\": [\"capital\", \"north america\"],\n      \"correctAnswerIndex\": 2\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/quizzes/{{quizId}}/questions",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "quizzes",
                "{{quizId}}",
                "questions"
              ]
            }
          }
        }
      ]
    }
  ]
}
